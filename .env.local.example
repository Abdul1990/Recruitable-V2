# ─── Copy this file to .env.local and fill in real values ───────────────────
# NEVER commit .env.local to git — it is in .gitignore

# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn OAuth (register at https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Firebase Admin SDK (Service Account — from Firebase console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=recruitable-asia
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@recruitable-asia.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=recruitable-asia.appspot.com

# App base URL (used to build OAuth redirect URIs)
NEXT_PUBLIC_BASE_URL=https://recruitable.asia
# For local dev:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Zoom (Server-to-Server OAuth App) ──────────────────────────────────────
# Create at: https://marketplace.zoom.us/develop/create → Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ─── Google Meet (via Google Calendar API) ───────────────────────────────────
# Create a service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable the Google Calendar API, share your calendar with the service account email
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary

# ─── ATS Notes (optional — only needed if pushing notes back to ATS) ─────────
# Greenhouse Harvest API key (Settings → Dev Centre → API Credential Management)
GREENHOUSE_HARVEST_API_KEY=
GREENHOUSE_ON_BEHALF_OF_EMAIL=
GREENHOUSE_BOT_USER_ID=
# Lever private API key (Settings → Integrations → API)
LEVER_API_KEY=

# Vercel Cron secret — set automatically by Vercel in production
# For local testing: generate any random string
CRON_SECRET=
